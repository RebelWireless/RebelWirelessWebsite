# Rebel Wireless Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# Discord Webhooks for form notifications
DISCORD_SIGNUP_WEBHOOK_URL=https://discord.com/api/webhooks/your-signup-webhook-url
DISCORD_CONTACT_WEBHOOK_URL=https://discord.com/api/webhooks/your-contact-webhook-url
